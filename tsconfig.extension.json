{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "outDir": "out",
        "types": [
            "node",
            "vscode"
        ],
        "lib": [
            "ES2018"
        ],
        "allowJs": true,
        "checkJs": false
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.js"
    ],
    "exclude": [
        "test/**",
        "out/**",
        "out-tests/**",
        "out-scripts/**",
        "dist/**",
        "node_modules/**"
    ]
}
