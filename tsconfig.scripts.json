{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "outDir": "out-scripts",
        "types": [
            "node"
        ],
        "lib": [
            "ES2018"
        ],
        "allowJs": true,
        "checkJs": false
    },
    "include": [
        "scripts/**/*.ts",
        "scripts/**/*.js"
    ],
    "exclude": [
        "node_modules/**",
        "out/**",
        "out-tests/**",
        "out-scripts/**",
        "scripts/build-color-theme.js",
        "scripts/check-codex-docs.js",
        "scripts/e2e-last-run.js",
        "scripts/run-e2e.js"
    ]
}
